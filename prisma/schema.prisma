generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  password        String
  nickname        String      @unique
  bio             String?     @default("")
  profileColor    String?     @default("#ff3b9a")
  title           String?     @default("Fresh Degen")
  xp              Int         @default(0)

  // New MySpace-style fields
  mood            String?     @default("vibing")
  currentlyDoing  String?     @default("")
  specialty       String?     @default("")
  themeSongUrl    String?
  themeSongLabel  String?

  // Top 8 watchdogs (array of user IDs, ordered)
  topWatchdogIds  String[]    @default([])

  createdAt       DateTime    @default(now())

  // Relations
  reports           Report[]
  confirms          Confirm[]
  comments          Comment[]
  roastVotes        RoastVote[]
  roasts            Roast[]
  bounties          Bounty[]
  wallPosts         WallPost[]  @relation("wallOwner")
  wallPostsWritten  WallPost[]  @relation("wallAuthor")
  disputes          Dispute[]
  linkedWallets     LinkedWallet[]
  evidence          Evidence[]
  watches           Watch[]
  commentVotes      CommentVote[]
}

model Report {
  id            String      @id @default(cuid())
  type          String      // "deployer" or "twitter"
  identifier    String      // wallet address or twitter handle
  reason        String
  evidence      String?
  chain         String?     @default("ETH")

  author        User        @relation(fields: [authorId], references: [id])
  authorId      String

  confirms      Confirm[]
  disputes      Dispute[]
  comments      Comment[]
  roasts        Roast[]
  bounties      Bounty[]
  linkedWallets LinkedWallet[]
  evidenceItems Evidence[]

  shameLocked   Boolean     @default(false)
  roastTitle    String?
  disputeCount  Int         @default(0)

  // Subscammer (community/category) relation
  subscammer    Subscammer? @relation(fields: [subscammerId], references: [id])
  subscammerId  String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([identifier])
  @@index([createdAt])
  @@index([subscammerId])
}

model Confirm {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  isVictim  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
}

model Dispute {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String

  // Threading support
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  // Votes
  votes     CommentVote[]

  createdAt DateTime @default(now())
}

model Roast {
  id        String      @id @default(cuid())
  text      String      // max 60 chars - the roast title
  author    User        @relation(fields: [authorId], references: [id])
  authorId  String
  report    Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  votes     RoastVote[]
  createdAt DateTime    @default(now())
}

model RoastVote {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  roast     Roast    @relation(fields: [roastId], references: [id], onDelete: Cascade)
  roastId   String
  createdAt DateTime @default(now())

  @@unique([userId, roastId])
}

model Bounty {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  message   String?
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
}

model WallPost {
  id        String   @id @default(cuid())
  body      String   // max 280 chars

  user      User     @relation("wallOwner", fields: [userId], references: [id])
  userId    String   // whose wall this is on

  author    User     @relation("wallAuthor", fields: [authorId], references: [id])
  authorId  String   // who wrote the post

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Subscammer {
  id          String   @id @default(cuid())
  slug        String   @unique // "rugpulls", "honeypots", etc.
  name        String   // "Rug Pulls"
  description String?
  reports     Report[]
  createdAt   DateTime @default(now())
}

model LinkedWallet {
  id           String   @id @default(cuid())
  identifier   String   // the linked wallet address or twitter handle
  type         String   // "deployer" or "twitter"
  relationship String   // user description: "funded primary", "received drained LP", etc.

  report       Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId     String

  addedBy      User     @relation(fields: [userId], references: [id])
  userId       String

  confirms     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([reportId])
  @@index([identifier])
}

model Evidence {
  id        String   @id @default(cuid())
  type      String   // "tx", "screenshot", "contract", "graph", "link"
  url       String   // the evidence URL
  source    String   // "solscan.io", "twitter", "discord", "telegram", "etherscan", "arkham", etc.
  summary   String   // short description, max 120 chars

  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String

  addedBy   User     @relation(fields: [userId], references: [id])
  userId    String

  createdAt DateTime @default(now())

  @@index([reportId])
}

model Watch {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  // Polymorphic — watching either a scammer or a user
  targetType String   // "scammer" or "user"
  targetId   String   // report identifier (for scammers) or user ID (for users)

  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId])
}

model CommentVote {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}
